{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CNexus 2.0",
  "version": "2.4.1",
  "identifier": "com.cnexus.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000/desktop",
    "beforeBuildCommand": "",
    "frontendDist": "../out"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "float",
        "title": "CNexus",
        "width": 360,
        "height": 228,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "shadow": false,
        "visible": false,
        "skipTaskbar": true,
        "resizable": false,
        "url": "/desktop"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "runtime-bundle/",
      "resources/help/",
      "icons/icon.ico",
      "windows/restart-cnexus-desktop.ps1",
      "windows/CNexus-restart.bat"
    ],
    "externalBin": [
      "cnexus-runtime"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installerHooks": "./windows/hooks.nsh",
        "uninstallerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {}
}