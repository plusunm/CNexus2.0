{
  "name": "cnexus-product",
  "version": "0.1.0-alpha",
  "private": true,
  "description": "CNexus Product — standalone Mind UI with optional Runtime binding",
  "repository": {
    "type": "git",
    "url": "https://github.com/plusunm/CNexus.git",
    "directory": "brain-memory-ui/frontend"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "app",
    "components",
    "hooks",
    "lib",
    "public",
    "scripts",
    "next.config.ts",
    "tailwind.config.ts",
    "postcss.config.mjs",
    "tsconfig.json",
    "Dockerfile",
    "docker-entrypoint.sh"
  ],
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:demo": "tsx scripts/verify-demo-contract.ts",
    "test:boot-protocol": "tsx scripts/verify-boot-shell-protocol.ts",
    "test:kernel-boundary": "tsx scripts/verify-kernel-boundary.ts",
    "tauri:icons": "node scripts/generate-tauri-icons.mjs && node scripts/ensure-tauri-icons.mjs --force",
    "tauri:icons:ensure": "node scripts/ensure-tauri-icons.mjs",
    "kill:cnexus": "cmd /c \"..\\..\\scripts\\kill-cnexus-before-build.bat\"",
    "restart:desktop": "powershell -ExecutionPolicy Bypass -File ../../scripts/restart-cnexus-desktop.ps1 -TryStartOllama",
    "build:installer": "powershell -ExecutionPolicy Bypass -File ../../scripts/build-cnexus-installer.ps1",
    "build:tauri": "cross-env CNEXUS_RELEASE=1 node scripts/write-cnexus-config.mjs personal && cross-env CNEXUS_TAURI=1 CNEXUS_RELEASE=1 next build",
    "bundle:runtime": "npm run kill:cnexus && powershell -ExecutionPolicy Bypass -File ../../scripts/bundle-runtime-for-desktop.ps1",
    "build:desktop": "npm run bundle:runtime && npm run build:tauri",
    "build:personal": "node scripts/write-cnexus-config.mjs personal && cross-env CNEXUS_TAURI=1 next build && node scripts/sync-ui-export.mjs",
    "build:enterprise": "node scripts/write-cnexus-config.mjs enterprise && cross-env CNEXUS_TAURI=1 next build",
    "dev:ui": "node scripts/write-cnexus-config.mjs && next dev -p 3000",
    "dev:desktop": "powershell -ExecutionPolicy Bypass -File ../scripts/dev-desktop.ps1 -Mode tauri",
    "dev:browser": "powershell -ExecutionPolicy Bypass -File ../scripts/dev-desktop.ps1 -Mode browser",
    "tauri:dev": "tauri dev",
    "tauri:dev:icons": "npm run tauri:icons && tauri dev",
    "prebuild:check": "powershell -ExecutionPolicy Bypass -File ../../scripts/prebuild-check.ps1",
    "prebuild:toolchain": "powershell -ExecutionPolicy Bypass -File ../../scripts/prebuild-toolchain-check.ps1",
    "env:vs-native": "powershell -ExecutionPolicy Bypass -File ../../scripts/env-vs-native.ps1",
    "prebuild:vs-preflight": "powershell -ExecutionPolicy Bypass -File ../../scripts/run-in-vs-native.ps1 \"cd /d ..\\..\\brain-memory-ui\\frontend && npm run prebuild:toolchain && npm run prebuild:gate && npm run prebuild:smoke\"",
    "tauri:build:vs": "powershell -ExecutionPolicy Bypass -File ../../scripts/run-in-vs-native.ps1 \"cd /d ..\\..\\brain-memory-ui\\frontend && npm run tauri:build\"",
    "prebuild:audit": "powershell -ExecutionPolicy Bypass -File ../../scripts/prebuild-audit-full.ps1",
    "prebuild:audit:float": "powershell -ExecutionPolicy Bypass -File ../../scripts/prebuild-audit-float.ps1",
    "prebuild:gate": "powershell -ExecutionPolicy Bypass -File ../../scripts/prebuild-release-gate.ps1",
    "prebuild:smoke": "powershell -ExecutionPolicy Bypass -File ../../scripts/prebuild-smoke-gate.ps1",
    "prebuild:smoke:ui": "powershell -ExecutionPolicy Bypass -File ../../scripts/prebuild-ui-smoke-gate.ps1",
    "prebuild:gate:strict": "powershell -ExecutionPolicy Bypass -File ../../scripts/prebuild-release-gate.ps1 -Strict",
    "prebuild:signoff:draft": "powershell -ExecutionPolicy Bypass -File ../../scripts/prepare-manual-signoff.ps1",
    "prebuild:rc-report": "powershell -ExecutionPolicy Bypass -File ../../scripts/prebuild-rc-report.ps1",
    "prebuild:release": "npm run prebuild:toolchain && npm run prebuild:gate && npm run prebuild:smoke",
    "verify:runtime-bundle": "powershell -ExecutionPolicy Bypass -File ../../scripts/verify-runtime-bundle.ps1",
    "build:sidecar": "powershell -ExecutionPolicy Bypass -File ../scripts/build-desktop-sidecar.ps1",
    "tauri:build": "npm run kill:cnexus && npm run prebuild:check && npm run typecheck && npm run tauri:icons:ensure && npm run build:desktop && npm run verify:runtime-bundle && npm run build:sidecar && tauri build",
    "docker:build": "docker build -t cnexus-product .",
    "docker:run": "docker run --rm -p 3000:3000 -e CNEXUS_API_BASE=http://localhost:8000 cnexus-product"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.2.0",
    "@tauri-apps/plugin-global-shortcut": "^2.2.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.460.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.13.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.2.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "cross-env": "^7.0.3",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0"
  }
}
